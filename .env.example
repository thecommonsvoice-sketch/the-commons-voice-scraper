# ==========================================
# BACKEND API
# ==========================================
API_BASE_URL=http://localhost:3000
REPORTER_EMAIL=reporterauto@thecommonsvoice.com
REPORTER_PASSWORD=reporterAuto123pass

# ==========================================
# GROQ AI (get from https://console.groq.com)
# ==========================================
GROQ_API_KEY=your-groq-api-key-here

# ==========================================
# CLOUDINARY (from your backend .env)
# ==========================================
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_UPLOAD_PRESET=unsigned_upload

# ==========================================
# SCHEDULER
# ==========================================
SCHEDULE_INTERVAL=60
LOG_LEVEL=info